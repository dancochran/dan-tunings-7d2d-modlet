<configs>
  <!-- increase skill book probability -->
  <set xpath="//lootgroup[starts-with(@name, 'group')]/item[@group='booksAllScaled']/@loot_prob_template">high</set>
  <set xpath="//lootgroup[starts-with(@name, 'group')]/item[@group='skillMagazines']/@loot_prob_template">high</set>
  <set xpath="//lootgroup[starts-with(@name, 'groupJunk')]/item[@group='booksAllScaled']/@loot_prob_template">med</set>
  <set xpath="//lootgroup[starts-with(@name, 'groupJunk')]/item[@group='skillMagazines']/@loot_prob_template">med</set>

  <!-- increase feathers/eggs -->
  <set xpath="//lootgroup[@name='groupBirdNest01']/item[@name='resourceFeather']/@count">5,10</set>
  <set xpath="//lootgroup[@name='groupBirdNest02']/item[@name='resourceFeather']/@count">5,10</set>
  <set xpath="//lootgroup[@name='groupBirdNest02']/item[@name='foodEgg']/@loot_prob_template">high</set>

  <!-- acid -->
  <append xpath="//lootgroup[@name='groupCupboard02']">
    <item name="resourceAcid" count="1,2" loot_prob_template="low"/>
  </append>

  <!-- increase lockpicks found -->
  <set xpath="//lootgroup/item[@name='resourceLockPick']/@count">3,10</set>

  <!-- backpack -->
  <set xpath="/lootcontainers/lootcontainer[@name='playerBackpack']/@size">11,13</set>

</configs>
